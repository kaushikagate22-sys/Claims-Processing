# Copy to .env and fill in. Everything runs WITHOUT any key (offline fallback).
# Set ONE provider key to enable real LLM extraction & reasoning.

# --- Option A: OpenAI ---
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Option B: Anthropic ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Force a provider explicitly (openai | anthropic | offline).
# If unset, the platform auto-detects from whichever key is present
# (OpenAI preferred if both are set).
LLM_PROVIDER=

# Optional global overrides
# LLM_MODEL=            # overrides the per-provider default model
LOG_LEVEL=INFO
RETRIEVER_TOP_K=4

# --- database (Stage 1 persistence) ---
# Leave blank for local SQLite (./claims.db). For your Azure Postgres set:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST.postgres.database.azure.com:5432/DBNAME?sslmode=require
DATABASE_URL=
