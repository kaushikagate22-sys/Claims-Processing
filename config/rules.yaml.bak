# =============================================================
# config/rules.yaml  (AUTO-GENERATED by domain.policy_compiler)
# Source of truth: data/policies/master_policy.md
# Re-run `python examples/compile_policy.py` after editing the policy.
# The `claim_types` block below is regenerated; `rules` is preserved.
# =============================================================

claim_types: {}
rules:
- id: has_policy_number
  field: policy_number
  op: exists
  severity: hard
  category: completeness
  message: Policy number is missing from the claim.
- id: has_claimant_name
  field: claimant_name
  op: exists
  severity: soft
  category: completeness
  message: Claimant name could not be identified.
- id: has_incident_date
  field: incident_date
  op: exists
  severity: soft
  category: completeness
  message: Incident date is missing.
- id: has_claim_amount
  field: claim_amount
  op: exists
  severity: hard
  category: completeness
  message: Claim amount is missing.
- id: amount_positive
  field: claim_amount
  op: gt
  value: 0
  severity: hard
  category: eligibility
  message: Claim amount must be greater than zero.
- id: cause_not_excluded
  field: excluded
  op: falsy
  severity: hard
  category: eligibility
  message: The claimed cause falls under a policy exclusion.
- id: policy_active
  field: policy_active
  op: truthy
  severity: hard
  category: eligibility
  message: Policy was not active on the incident date.
- id: amount_within_limit
  field: claim_amount
  op: lte
  value: $coverage_limit
  severity: soft
  category: eligibility
  message: Claim amount exceeds the coverage limit; payable up to the limit.
- id: policy_on_record
  field: policy_exists
  op: truthy
  severity: hard
  category: eligibility
  message: No matching policy was found in the system of record.
- id: within_policy_period
  field: within_policy_period
  op: truthy
  severity: hard
  category: eligibility
  message: Incident date falls outside the active policy period on record.
- id: not_duplicate
  field: not_duplicate
  op: truthy
  severity: hard
  category: eligibility
  message: A settled claim for this policy and incident date already exists (possible
    duplicate).
- id: claimant_matches_record
  field: name_match
  op: truthy
  severity: soft
  category: review
  message: Claimant name does not match the policyholder/nominee on record.
- id: product_matches_claim
  field: product_matches
  op: truthy
  severity: soft
  category: review
  message: Claim type does not match the policy product on record.
